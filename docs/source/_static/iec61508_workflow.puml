@startuml
left to right direction
hide stereotype
skinparam shadowing false
skinparam RoundCorner 14
skinparam ArrowThickness 1.3
skinparam ArrowColor #2f2f2f
skinparam defaultFontName Arial
skinparam defaultFontSize 16

' --- Top Row: Core lifecycle ---
rectangle "HAZ_ESTOP_01\nHazard" as HAZ #EAF2FF
rectangle "RISK_ESTOP_01\nRisk [ADDRESSES]" as RISK #EAF2FF
rectangle "SIL_ESTOP_01\nSIL [ALLOCATES]" as SIL #EAF2FF
rectangle "FSR_ESTOP_01\nFSR [REFINES]" as FSR #EFE8FF
rectangle "TSR_ESTOP_01\nTSR [REFINES]" as TSR #EFE8FF
rectangle "ARCH_ESTOP_01\nArch [REALIZES]" as ARCH #E7F7EE

HAZ --> RISK
RISK --> SIL
SIL --> FSR
FSR --> TSR
TSR -down-> ARCH

' --- Bottom Row: V&V + Confirmation (right → left) ---
rectangle "VERIF_ESTOP_01\nVerif [VERIFIES]" as VERIF #FFF4D6
rectangle "EVID_ESTOP_01\nEvidence [EVIDENCES]" as EVID #FFF4D6
rectangle "CONFIRM_ESTOP_01\nConfirm [REVIEWS]" as CONF #FFE6EA

EVID -left-> VERIF
VERIF -up-> FSR
CONF -up-> SIL

' Alignment helpers
CONF -[hidden]-> EVID
VERIF -[hidden]-> ARCH

@enduml