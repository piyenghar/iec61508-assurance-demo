@startuml IEC61508MetaModel

skinparam Dpi 300
skinparam backgroundColor white
skinparam shadowing false
skinparam roundcorner 6
skinparam DefaultFontName Arial
skinparam DefaultFontSize 12

skinparam ArrowColor #1F2D3A
skinparam ArrowThickness 1.4
skinparam linetype ortho
skinparam ArrowFontSize 10

skinparam nodesep 65
skinparam ranksep 50
skinparam padding 10

' Remove extra class compartments (those horizontal lines)

' Make edge labels slightly smaller than box text (helps clutter)
skinparam ArrowFontSize 10

skinparam class {
  BorderColor #1F2D3A
  BorderThickness 1.4
  FontColor #111111
}

title Assurance artefact vocabulary (meta-model)

' --- Phase color coding ---
class Hazard <<hazard>> #E8F1FB {
  --
}

class RiskAssessment <<risk>> #E8F1FB {
  --
}

class SILAllocation <<sil>> #E8F1FB {
  --
}

class FSR <<fsr>> #EFE9FB {
  --
}

class TSR <<tsr>> #EFE9FB {
  --
}

class Architecture <<arch>> #E9F7EF {
  --
}

class Verification <<verif>> #FFF8E6 {
  --
}

class Evidence <<evidence>> #FFF8E6 {
  --
}

class Confirmation <<confirm>> #FDEDEC {
  --
}

' --- Row 1 (left → right) ---
Hazard         -right-> RiskAssessment : ADDRESSES
RiskAssessment -right-> SILAllocation  : ALLOCATES
SILAllocation  -right-> FSR            : REFINES
FSR            -right-> TSR            : REFINES

' --- Drop correctly ---
TSR -down-> Architecture : REALIZES

' --- Row 2 (right → left visual compacting; semantics preserved) ---
Architecture -left-> Verification : VERIFIES
Verification -left-> Evidence     : EVIDENCES
Evidence     -left-> Confirmation : REVIEWS

@enduml